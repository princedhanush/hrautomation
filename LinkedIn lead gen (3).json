      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n\n  const organic = item.json.results?.results?.organic || [];\n\n  for (const r of organic) {\n\n    if (r.link && r.link.includes(\"linkedin.com/in\")) {\n\n      const parts = r.title ? r.title.split(\" - \") : [];\n\n      output.push({\n        json: {\n          name: parts[0] || \"\",\n          role: parts[1] || \"\",\n          linkedin_url: r.link,\n          summary: r.snippet || \"\"\n        }\n      });\n\n    }\n\n  }\n\n}\n\nreturn output;"
      },
