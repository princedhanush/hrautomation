      "parameters": {
        "jsCode": "// Get raw content\nlet raw = $json.content;\n\n// Clean unwanted characters\nraw = raw\n  .replace(/\\n/g, '')\n  .replace(/\\r/g, '')\n  .replace(/\\t/g, '')\n  .trim();\n\n// Parse JSON safely\nconst parsed = JSON.parse(raw);\n\n// Extract queries\nconst queries = parsed.queries || [];\n\n// Return each query as item\nreturn queries.map(q => ({\n  json: {\n    query: q\n  }\n}));"
      },
