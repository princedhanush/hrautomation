    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a clean and professional interview invitation email.\n\nDetails:\nName: {{ $node[\"Webhook\"].json.body.NAME }}\nSkills: {{ $node[\"Webhook\"].json.body.SKILLS }}\nDate & Time: {{$('Code').item.json.readableTime}}\nCalendar Link:\nMeeting Link: {{$json.hangoutLink}}\n\n📌 A calendar invitation has been sent to your email.\nIf you don’t see it in your calendar, please click “Add to calendar” in the invite.\n\nInstructions:\n- Keep it short and professional\n- Use simple sentences\n- Do not repeat information\n- Do not add extra explanation\n- Output only the email body\n\nFormat:\n\nHello {{ $node[\"Webhook\"].json.body.NAME }},\n\nWe are Mondee, a global travel technology company.\n\nCongratulations! Your profile has been shortlisted.\n\nYour interview details:\nDate & Time: {{ $('Code').item.json.readableTime }}\n\nJoin Meeting:\n{{$json.hangoutLink}}\n\n📌 A calendar invitation has been sent to your email.\nIf you don’t see it in your calendar, please click “Add to calendar” in the invite.\n\n\nPlease join on time.\n\nBest regards,  \nDhanush  \nMondee",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "You are a professional HR email writer.  Rules: - Keep sentences short - Keep tone professional - Avoid long paragraphs - No extra text outside email"
            }
          ]
        },
        "batching": {}
      },
