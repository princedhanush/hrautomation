      "id": "674ad275-89cf-4430-b229-350d4e045d9f",
      "name": "Structured Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "position": [
        624,
        352
      ],
      "typeVersion": 1.2
    },
    {
      "parameters": {
        "jsCode": "const webhookItems = $items(\"Webhook\");\nif (!webhookItems || webhookItems.length === 0) {\n  return { json: { error: \"CRITICAL: Could not find the Webhook memory!\" } };\n}\n\nconst webhookData = webhookItems[0].json.body;\nconst rawDate = webhookData.Date;\nconst rawTime = webhookData.TIME;\nconst voteRaw = $json.VOTE;\n\nif (!rawDate || !rawTime || rawDate.toString().trim() === \"\" || rawTime.toString().trim() === \"\") {\n  return { json: { error: \"FAILED DATE CHECK\", rawDate: rawDate, rawTime: rawTime } };\n}\n\nlet vote = voteRaw ? voteRaw.toString().toLowerCase().trim() : \"\";\nlet voteNumber = parseFloat(vote);\nlet isNumericQualified = !isNaN(voteNumber) && voteNumber >= 7 && voteNumber <= 10;\nlet isTextQualified = vote === \"yes\" || vote === \"shortlisted\" || vote === \"shortlist\" || vote === \"highly recommended\"; \n\nif (!(isNumericQualified || isTextQualified)) {\n  return { json: { error: \"FAILED VOTE CHECK\", originalVote: voteRaw, normalizedVote: vote } };\n}\n\nlet year, month, day;\nlet dateStr = rawDate.toString().trim();\n\nif (typeof rawDate === \"number\") {\n  const d = new Date((rawDate - 25569) * 86400 * 1000);\n  year = d.getFullYear(); month = d.getMonth() + 1; day = d.getDate();\n} else if (dateStr.includes(\"T\")) {\n  const d = new Date(dateStr);\n  year = d.getFullYear(); month = d.getMonth() + 1; day = d.getDate();\n} else if (dateStr.includes(\"-\")) {\n  const parts = dateStr.split(\"-\").map(Number);\n  if (parts[0] > 31) { [year, month, day] = parts; } else { [day, month, year] = parts; }\n} else if (dateStr.includes(\"/\")) {\n  const parts = dateStr.split(\"/\").map(Number);\n  if (parts[2] > 31) { [day, month, year] = parts; } else { [month, day, year] = parts; }\n} else { \n  return { json: { error: \"FAILED PARSING FORMAT\", dateStr: dateStr } };\n}\n\nconst [hours, minutes] = rawTime.toString().split(\":\").map(Number);\n\nif (isNaN(year) || isNaN(month) || isNaN(day) || isNaN(hours) || isNaN(minutes)) { \n  return { json: { error: \"FAILED PARSING (NaN)\", year, month, day, hours, minutes } };\n}\n\nconst start = new Date(year, month - 1, day, hours, minutes);\nstart.setMinutes(start.getMinutes() - 330);\nconst end = new Date(start.getTime() + 60 * 60 * 1000);\n\nlet outputJson = Object.assign({}, $json);\noutputJson.skip = false;\noutputJson.nextSlot = start.toISOString();\noutputJson.endSlot = end.toISOString();\noutputJson.readableTime = new Date(start.getTime() + 330 * 60 * 1000).toLocaleString(\"en-IN\");\n\nreturn { json: outputJson };\n"
      },
